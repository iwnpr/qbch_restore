{
  // Пути к данным
  "Paths": {
    "ApiLogsDir": "logs",          // логи qbch_api (запросный XML + связки)
    "SaverLogsDir": "logs_saver",  // логи qbch_db_saver_sdc (пропавшие ключи)
    "MissingTxt": "missing.txt",   // выгрузка списка пропавших ключей (этап 1)
    "Db": "restore.db"             // локальная SQLite-база с промежуточными данными
  },

  // Подключение к Redis. Должны совпадать с настройками боевого qbch_api/saver.
  "Redis": {
    "ConnectionString": "localhost:6379",
    "DbIndex": 0,
    "TtlMinutes": 480 // время жизни восстановленного ключа (по умолчанию 8ч, как в оригинале)
  },

  // Подключение к Kafka. Topic должен совпадать с тем, который читает saver.
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "QBCHMessagesTopic_V3_27"
  }
}
